# TiDB Database Connection
# Get these from your TiDB Cloud console: https://cloud.tidbcloud.com/
DATABASE_URL="mysql://<USER>:<PASSWORD>@<HOST>:4000/servicetrack?sslaccept=strict"

# JWT Secret - Generate with: openssl rand -base64 64
JWT_SECRET="servicetrack-jwt-secret-key-change-this-in-production-2026"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
